{
  "id": null,
  "uid": "scada-turbina1-all",
  "title": "SCADA Turbina1 — Anomaly Detection",
  "tags": ["scada", "turbina1", "mqtt", "kafka", "flink", "ml"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 7,
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "type": "query",
        "name": "asset",
        "label": "Asset",
        "datasource": { "type": "postgres", "uid": "postgres" },
        "refresh": 1,
        "hide": 0,
        "includeAll": true,
        "allValue": "%",
        "multi": false,
        "options": [],
        "query": "SELECT DISTINCT asset FROM scada_turbina1_all ORDER BY 1",
        "current": { "text": "All", "value": "%" }
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "stat",
      "title": "ESTADO TURBINA G1",
      "description": "0 = Normal · 1 = Precaución (score > 30%) · 2 = CRÍTICO (ML o score > 60%)",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "NORMAL",    "color": "green",  "index": 0 },
                "1": { "text": "PRECAUCIÓN","color": "orange", "index": 1 },
                "2": { "text": "CRÍTICO",   "color": "red",    "index": 2 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red",    "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "text": { "valueSize": 48 }
      },
      "targets": [{
        "refId": "A",
        "rawQuery": true,
        "format": "table",
        "rawSql": "SELECT CASE WHEN if_anomaly = 1 OR anomaly_score > 0.6 THEN 2 WHEN anomaly_score > 0.3 THEN 1 ELSE 0 END AS estado FROM scada_turbina1_all WHERE $__timeFilter(ts) AND asset LIKE '$asset' ORDER BY ts DESC LIMIT 1"
      }]
    },
    {
      "id": 101,
      "type": "stat",
      "title": "Detección ML — Capa 2",
      "description": "Isolation Forest: si if_score ≤ −0.6998 → ANOMALÍA",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "NORMAL",   "color": "green", "index": 0 },
                "1": { "text": "ANOMALÍA", "color": "red",   "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "justifyMode": "center",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "text": { "valueSize": 42 }
      },
      "targets": [{
        "refId": "A",
        "rawQuery": true,
        "format": "table",
        "rawSql": "SELECT if_anomaly FROM scada_turbina1_all WHERE $__timeFilter(ts) AND asset LIKE '$asset' AND if_anomaly IS NOT NULL ORDER BY ts DESC LIMIT 1"
      }]
    },
